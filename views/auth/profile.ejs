<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="referrer" content="no-referrer">
    <title>Profile Page</title>
    <link rel="icon" href="/images/download.png" type="image/png">
    <link rel="stylesheet" href="/profile.css">
</head>
<body>
    <%- include('../partials/header') %>
    <main>
        <div class="profile-page">
            <h1>Your Profile</h1>
            <div class="profile-card">
                <div class="basic-details">
                    <section class="avatar-placeholder">
                        <% if (user.avatarUrl) { %>
                            <span><img src="<%= user.avatarUrl %>" alt="avatar"></span>
                        <% } else  {%>
                            <span><%= user.name.charAt(0).toUpperCase() %></span>
                        <% } %>
                        <a class="edit-image" href="/change-profile">
                            <img src="/images/pencil-solid.svg">
                        </a>
                    </section>
                    <section id="user-detail" style="width: 100%; overflow: hidden;">
                        <p class="name"><%= user.name.toUpperCase() %></p>
                        <div class="name-ctr hide">
                            <input class="input-name name">
                            <button class="ctrl-btn">Update Name</button>
                        </div>
                        <div>
                            <img src="/images/email.svg" alt="email"/>
                            <p><%= user.email %></p>
                        </div>
                        <div>
                            <img src="/images/calendar.svg" alt="calendar"/>
                            <p>Member since <%= user.createdAt %></p>
                        </div>
                    </section>
                </div>
                <div class="links-related">
                    <section class="links">
                        <p class="links-qty"><%= user.links ? user.links.length : 0 %></p>
                        <p class="links-head">LINKS CREATED</p>
                    </section>
                    <section class="links">
                        <p class="links-qty"><%= user.totalClicks %></p>
                        <p class="links-head">TOTAL CLICKS</p>
                    </section>
                    <section class="links">
                        <p class="links-qty"><%= user.lastActive ? new Date(user.lastActive).toLocaleDateString() : 'Today' %></p>
                        <p class="links-head">LAST ACTIVE</p>
                    </section>
                </div>
                <div class="email-verify">
                    <div class="verify-head">Email</div>
                    <% if(user.isEmailVerified) { %>
                        <div class="ver-status" style="background-color: #3AB43AFF">Verified</div>
                    <% } else { %>
                        <div class="ver-status" style="background-color: #ff6b6b">Unverified</div>
                        <a class="verify" href="/verify-email">
                            <div class="svg-wrapper-1">
                                <div class="svg-wrapper">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24">
                                        <path fill="none" d="M0 0h24v24H0z"></path>
                                        <path fill="currentColor" d="M1.946 9.315c-.522-.174-.527-.455.01-.634l19.087-6.362c.529-.176.832.12.684.638l-5.454 19.086c-.15.529-.455.547-.679.045L12 14l6-8-8 6-8.054-2.685z"></path>
                                    </svg>
                                </div>
                            </div>
                            <span>Verify</span>
                        </a>
                    <% } %>
                </div>
            </div>
            <div class="controls">
                <button class="ctrl-btn">
                    <% if (user.onlineSignIn) { %>
                        <a href="/set-password">Set Password</a>
                    <% } else { %>
                        <a href="/change-password">Change Password</a>
                    <% } %>
                </button>
                <button class="ctrl-btn">Change Name</button>
                <button class="ctrl-btn"><a href="/logout">Logout</a></button>
            </div>
        </div>
    </main>
    <script>
        // Get the Edit Profile Button
        const editProfile = document.querySelectorAll('.controls .ctrl-btn')[1];
        const nameField = document.querySelector("p[class='name']");
        const nameInputCtr = document.querySelector('.name-ctr');
        editProfile.addEventListener('click', (event) => {
            event.preventDefault();
            nameField.classList.toggle("hide");
            nameInputCtr.classList.toggle("hide");
        });

        //* getting change button
        const changeBtn = document.querySelector(".name-ctr button");
        const inputName = document.querySelector(".input-name");
        
        changeBtn.addEventListener('click', async (event) => {
            event.preventDefault();
            try {
                console.log(inputName.value);
                const response = await fetch("/change-name", {
                    method : "POST",
                    headers: {"Content-Type" : "application/json"},
                    body : JSON.stringify({name : inputName.value})
                });
                if (response.ok) {
                    window.location.reload();
                }
                else {
                    const error = await response.json();
                    alert(error.error);
                    window.location.reload();
                }
            } catch (error) {
                console.error(error);
            }
        })
    </script>
</body>
</html>