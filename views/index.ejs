<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="./Images/download.png" type="image/png">
    <title>URL Shortener App</title>
    <link rel="stylesheet" href="./style.css">
</head>
<body>
    <%- include('./partials/header') %>
    <!--    <% if(username) { %>-->
    <!--        <h2>Welcome, <%= username %></h2>-->
    <!--    <% } else { %>-->
    <!--        <h2>Please Log in.</h2>-->
    <!--    <% } %>-->
    <main>
        <div class="container">
            <div class="status" style="background-color: <%= (username ? '#d6fcc0' : '#fcc0c0') %>">
                <img src="./Images/<%= (username ? "logged" : "notlogged") %>.svg" alt=`<%= (username ? "logged" : "notlogged") %>`/>
                <p>You are <%= (username ? "" : "not ") %>logged in</p>
            </div>
            <h1>URL Shortener App</h1>
            <form action="/" method="post">
                <div>
                    <label for="url">Enter URL: </label>
                    <input type="text" name="url" id="url" required>
                </div>
                <div>
                    <label for="shortCode">Enter Short Code [Optional]: </label>
                    <input type="text" name="shortCode" id="shortCode">
                </div>
                <% if (errors && errors.length>0) { %>
                    <p class="alert"><%- errors[0] %></p>
                <% } %>
                <button type="submit">Shorten It </button>
            </form>
            
            <h2>Shortened URLs</h2>
            <ul id="shortened-urls">
                <% if(links.length>0) { %>
                    <% links.map(({id, shortCode, url, clicks}) => { %>
                        <li data-id="<%= id %>">
                            <div class="link-ctr">
                                <div class="link">
                                    <img src="./Images/link.svg" alt="link"/>
                                    <a href="/<%= shortCode %>" target="_blank" class="short-code-link"><%= host %>/<%= shortCode %></a>
                                </div>
                                <p><%= url %></p>
                            </div>
                            <div class="controls">
                                <span class="count-links"><%= clicks %></span>
                                <img src="./Images/qr-code.png" alt="qr-code" data-id="qr">
                                <img src="./Images/edit.svg" alt="edit" class="edit" data-id="edit"/>
                                <img src="./Images/delete.svg" alt="cancel" data-id="delete"/>
                            </div>
                            <div class="filter-bg">
                                <div class="filter-popup">
                                    <div class="filter">
                                        <label style="font-weight: bold; font-size: 1.2rem">Update Details for ID: <%=id%></label>
                                        <form data-id="update-box">
                                            <div>
                                                <label for="url-<%= id %>">Enter URL: </label>
                                                <input type="text" name="url" id="url-<%= id %>" value=<%= url %> required>
                                            </div>
                                            <div>
                                                <label for="shortCode-<%= id %>">Enter Short Code [Optional]: </label>
                                                <input type="text" name="shortCode" id="shortCode-<%= id %>" value=<%= shortCode%>>
                                            </div>
                                            <button type="submit">Update</button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                            <div class="filter-bg">
                                <div class="filter-popup">
                                    <div class="qr-code" style="text-align: center;">
                                        <div>
                                            <p style="font-weight: bold; font-size: 1.5rem">QR Code</p>
                                            <p class="url-qr"><%= host %>/<%= shortCode %></p>
                                        </div>
                                        <img alt="qr-code" class="qr-preview" data-code="<%= host %>/<%= shortCode %>">
                                        <label style="font-size: 1rem">Scan using QR Code Scanner</label>
                                    </div>
                                </div>
                            </div>
                        </li>
                    <% }) %>
                <% } else { %>
                    <li>
                        <div class="link-ctr">No shortcodes to show.</div>
                    </li>
                <% } %>
            </ul>
        </div>
    </main>

    <%# Pagination component %>
        <% if (totalPages > 1) { %>
            <div class="pagination">
                <%# Previous page link %>
                <% if (currentPage > 1) { %>
                    <a href="?page=<%= currentPage - 1 %>" class="page-link">&laquo; Previous</a>
                <% } else { %>
                    <span class="page-link disabled">&laquo; Previous</span>
                <% } %>

                <!-- <span class="page-link current"> <%= currentPage %></span> -->
                
                <%# Calculate the range of page numbers to display %>
                <% let startPage = Math.max(1, currentPage - 2); %>
                <% let endPage = Math.min(totalPages, currentPage + 2); %>

                <%# Always show first page %>
                <% if (startPage > 1) { %>
                    <a href="?page=1" class="page-link">1</a>
                    <% if (startPage > 2) { %>
                        <span class="ellipsis">...</span>
                    <% } %>
                <% } %>
        
                <%# Show page numbers around current page %>
                <% for (let i = startPage; i <= endPage; i++) { %>
                    <% if (i === currentPage) { %>
                        <span class="page-link current"><%= i %></span>
                    <% } else { %>
                        <a href="?page=<%= i %>" class="page-link"><%= i %></a>
                    <% } %>
                <% } %>
 
                <%# Always show last page %>
                <% if (endPage < totalPages) { %>
                    <% if (endPage < totalPages - 1) { %>
                        <span class="ellipsis">...</span>
                    <% } %>
                    <a href="?page=<%= totalPages %>" class="page-link"><%= totalPages %></a>
                <% } %>
                      
                <%# Next page link %>
                <% if (currentPage < totalPages) { %>
                    <a href="?page=<%= currentPage + 1 %>" class="page-link">Next &raquo;</a>
                <% } else { %>
                    <span class="page-link disabled">Next &raquo;</span>
                <% } %>
           </div>
        <% } %>

    <script>
        //! delete shortcode
        const deleteImages = document.querySelectorAll("[data-id='delete']");
        deleteImages.forEach((img, index) => {
            img.addEventListener('click', () => {
                // Example: remove the corresponding <li> on click
                const li = img.closest('li');
                if (li) {
                    const url = li.querySelector('li div a').textContent;
                    const match = url.match(/([^/]+)\/?$/);
                    const shortCodetoDelete = (match) ? match[1] : null;
                    fetch(`/delete/${shortCodetoDelete}`, {
                        method: 'DELETE',
                    })
                    .then(res => res.json())
                    .then(data => {
                        (data.success) ? location.reload() : alert(data.message);
                    });
                }
            });
        });

        //! edit shortcodes, urls
        const editShortCodes = document.querySelectorAll("[data-id='edit']");  // Edit buttons
        editShortCodes.forEach((img, index) => {
            img.addEventListener('click', () => {
                const li = img.closest('li');
                const ID = li.dataset.id;
                const filterBg = li.querySelector(".filter-bg");
                const filterPopUp = li.querySelector(".filter-popup");
                const filter = li.querySelector(".filter");
                filterBg.classList.remove("inactive");
                filterPopUp.classList.remove("inactive");
                filterBg.classList.add("active");
                filterPopUp.classList.add("active");
                filterBg.addEventListener("click", (e) => {
                    if (e.target["classList"][0] === "filter-bg") {
                        filterBg.classList.remove("active");
                        filterPopUp.classList.remove("active");
                        filterBg.classList.add("inactive");
                        filterPopUp.classList.add("inactive");
                    }
                });
                const updateForm = li.querySelector('[data-id="update-box"]');
                updateForm.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    await edit(ID, updateForm, li);
                })
            });
        });

        // Fetch API for edit
        const edit = async (id, form, li) => {
            // Web APIs
            // const formData = new FormData(form, submitter);
            const formData = new FormData(form);
            const url = formData.get('url');
            const shortCode = formData.get('shortCode');
            console.log(url, shortCode);

            // Hitting API
            try {
                const response = await fetch(`/edit/${id}`, {
                    method : "PATCH",
                    headers: {"Content-Type": "application/json"},
                    body: JSON.stringify({url, shortCode})
                });
                const data = await response.json();

                if (response.ok) {
                    // alert('Successfully updated');
                    window.location.href = data.redirectTo;
                } else {
                    // Remove existing alerts
                    document.querySelectorAll(".alert").forEach(el => el.remove());

                    const submit_btn = li.querySelector('button[type="submit"]');
                    //! Creating alert message
                    const errorContainer = document.createElement("p");
                    errorContainer.className = "alert";

                    const errorStatus = response.statusText;
                    if (response.status === 409) {
                        errorContainer.innerHTML = `${errorStatus} : ${data.error}`;
                        // Append the alert above the register button
                        submit_btn.before(errorContainer);
                    }
                    else if (response.status === 404) {
                        alert(data.error.replaceAll('<br>', '\n'));
                        window.location.href = data.redirectTo;
                    } else
                        alert(errorStatus);
                }
            } catch (error) {
                console.error(error);
            }
        }

        //! create qr code
        const gen_qr_icons = document.querySelectorAll("[data-id='qr']"); // AllQR Codes buttons
        gen_qr_icons.forEach((img, index) => {
            img.addEventListener('click', async () => {
                const li = img.closest('li');
                const qrcode_img = li.querySelector(".qr-preview");
                // const ID = li.dataset.id;
                const data_code = qrcode_img.getAttribute('data-code');
                const filterBg = li.querySelectorAll(".filter-bg")[1];
                const filterPopUp = li.querySelectorAll(".filter-popup")[1];
                const qrcode = li.querySelector(".qr-code");
                filterBg.classList.remove("inactive");
                filterPopUp.classList.remove("inactive");
                filterBg.classList.add("active");
                filterPopUp.classList.add("active");
                if (qrcode_img.src) {
                    return; // Eliminates unecessary api calls
                }
                // fetch api to generate qr codes
                const res = await fetch(`/generate?text=${data_code}`, {
                    method : "GET",
                    headers: {'Accept': 'application/json'} // Ask for JSON response
                });
                if (res.ok) {
                    data = await res.json();
                    qrcode_img.src = data.qrCode;
                };
                filterBg.addEventListener("click", (e) => {
                    if (e.target["classList"][0] === "filter-bg") {
                        filterBg.classList.remove("active");
                        filterPopUp.classList.remove("active");
                        filterBg.classList.add("inactive");
                        filterPopUp.classList.add("inactive");
                    }
                });
            })
        })

        //! Setting height of list
        // const li = document.querySelectorAll("#shortened-urls li");
        // const height = li[0].clientHeight;
        // const list_ul = document.getElementById('shortened-urls');
        // list_ul['style'].height = `${height*(li.length>1 ? 2 : 1)+10}px`;
        // window.addEventListener("resize",(e) => {
        //     const li = document.querySelectorAll("#shortened-urls li");
        //     const height = li[0].clientHeight;
        //     console.log(height);
        //     list_ul['style'].height = `${height*(li.length>1 ? 2 : 1)+8}px`;
        // });
    </script>
</body>
</html>